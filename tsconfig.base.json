{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ClaudeShop Base",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "composite": false,
    "paths": {
      "@claudeshop/contracts": ["./packages/contracts/src/index.ts"],
      "@claudeshop/contracts/*": ["./packages/contracts/src/*"],
      "@claudeshop/core": ["./packages/core/src/index.ts"],
      "@claudeshop/core/*": ["./packages/core/src/*"],
      "@claudeshop/db": ["./packages/db/src/index.ts"],
      "@claudeshop/db/*": ["./packages/db/src/*"],
      "@claudeshop/sdk": ["./packages/sdk/src/index.ts"],
      "@claudeshop/sdk/*": ["./packages/sdk/src/*"],
      "@claudeshop/ui": ["./packages/ui/src/index.ts"],
      "@claudeshop/ui/*": ["./packages/ui/src/*"],
      "@claudeshop/errors": ["./packages/errors/src/index.ts"],
      "@claudeshop/errors/*": ["./packages/errors/src/*"],
      "@claudeshop/events": ["./packages/events/src/index.ts"],
      "@claudeshop/events/*": ["./packages/events/src/*"],
      "@claudeshop/telemetry": ["./packages/telemetry/src/index.ts"],
      "@claudeshop/telemetry/*": ["./packages/telemetry/src/*"],
      "@claudeshop/module-kit": ["./packages/module-kit/src/index.ts"],
      "@claudeshop/module-kit/*": ["./packages/module-kit/src/*"],
      "@claudeshop/config/*": ["./packages/config/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    ".next",
    "build",
    "coverage",
    "generated"
  ]
}
