{
  "name": "@claudeshop/api",
  "version": "0.1.0",
  "private": true,
  "description": "ClaudeShop API — Fastify + Prisma + GraphQL Yoga",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/server.ts",
    "start": "node --enable-source-maps dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@claudeshop/contracts": "workspace:*",
    "@claudeshop/core": "workspace:*",
    "@claudeshop/db": "workspace:*",
    "@claudeshop/errors": "workspace:*",
    "@claudeshop/events": "workspace:*",
    "@claudeshop/module-payment-stripe": "workspace:*",
    "@claudeshop/telemetry": "workspace:*",
    "bcryptjs": "^3.0.3",
    "@fastify/cors": "catalog:",
    "@fastify/helmet": "catalog:",
    "@fastify/rate-limit": "catalog:",
    "@fastify/sensible": "catalog:",
    "@fastify/under-pressure": "catalog:",
    "fastify": "catalog:",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "pino": "catalog:",
    "voyageai": "^0.2.1",
    "zod": "catalog:",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@claudeshop/config": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
