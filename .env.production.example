# ===============================================================
# ClaudeShop — Production environment template
# ---------------------------------------------------------------
# Copy to .env.production, fill in real values, chmod 600.
# In Coolify: paste each entry into the secret manager instead.
# NEVER commit .env.production to git.
# ===============================================================

# ----- Image tag (used by docker-compose.prod.yml) -----
IMAGE_TAG=latest

# ----- Public domains -----
DOMAIN_STOREFRONT=shop.example.com
DOMAIN_ADMIN=admin.shop.example.com
DOMAIN_API=api.shop.example.com

# ----- Node runtime -----
NODE_ENV=production
LOG_LEVEL=info

# ----- PostgreSQL -----
POSTGRES_USER=claudeshop
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=claudeshop

# ----- Redis -----
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ----- Meilisearch -----
MEILISEARCH_MASTER_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# ----- MinIO (S3-compatible) -----
MINIO_ACCESS_KEY=REPLACE_WITH_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=REPLACE_WITH_MINIO_SECRET_KEY
MINIO_BUCKET=claudeshop-media

# ----- SMTP relay -----
# Use a real relay (Brevo, Postmark, SES, Mailgun). Mailhog is dev-only.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM="ClaudeShop <no-reply@example.com>"

# ----- Auth.js v5 -----
# Generate with: openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# ----- Stripe (live keys) -----
STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# ----- Anthropic / Claude (AI runtime) -----
ANTHROPIC_API_KEY=sk-ant-REPLACE
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- OpenTelemetry (optional) -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=claudeshop-api
OTEL_RESOURCE_ATTRIBUTES=service.namespace=claudeshop,deployment.environment=production

# ----- Seed control -----
# In production keep SEED_DEMO unset or false — never expose demo@ account.
SEED_DEMO=false
