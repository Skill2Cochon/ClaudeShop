# Normalise line endings — LF everywhere in the repo, CRLF only in the working
# tree on Windows when git explicitly wants it. This keeps CI (Linux) and dev
# (Windows) consistent.
* text=auto eol=lf

# Binary files — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.woff binary
*.woff2 binary

# Keep Windows line endings for .bat / .cmd scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Keep LF for shell / makefiles / yaml / etc. regardless of platform
*.sh     text eol=lf
*.bash   text eol=lf
Makefile text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.prisma text eol=lf

# Mark autogenerated files so GitHub / Gitea collapses them in diffs.
packages/db/generated/**   linguist-generated=true
pnpm-lock.yaml             linguist-generated=true
