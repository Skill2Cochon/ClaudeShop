# ===============================================
# ClaudeShop — Environment Variables (Example)
# ===============================================
# Copy to .env and adjust for local dev.
# NEVER commit .env with real secrets.
# Production secrets live in a secret manager (e.g. Coolify, Doppler, Vault) —
# never in .env files checked into git.

# ----- Node -----
NODE_ENV=development
LOG_LEVEL=debug

# ----- API (apps/api) -----
API_HOST=0.0.0.0
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001

# ----- Storefront (apps/storefront) -----
STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----- Admin (apps/admin) -----
ADMIN_URL=http://localhost:3002

# ----- PostgreSQL -----
DATABASE_URL=postgresql://claudeshop:claudeshop@localhost:5432/claudeshop?schema=public
DIRECT_URL=postgresql://claudeshop:claudeshop@localhost:5432/claudeshop?schema=public

# ----- Redis -----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ----- Meilisearch -----
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=devMasterKeyChangeInProd

# ----- MinIO (S3-compatible) -----
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=claudeshop
MINIO_SECRET_KEY=claudeshop
MINIO_BUCKET=claudeshop-media

# ----- Email (Mailhog in dev) -----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@claudeshop.local

# ----- Auth.js v5 -----
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3002
AUTH_TRUST_HOST=true

# ----- Stripe (test keys) -----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- Claude API (AI features) -----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- OpenTelemetry -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=claudeshop-api
OTEL_RESOURCE_ATTRIBUTES=service.namespace=claudeshop,deployment.environment=dev
