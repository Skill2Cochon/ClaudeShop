{
  "name": "@claudeshop/events",
  "version": "0.1.0",
  "private": true,
  "description": "Typed event bus with transactional outbox pattern",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@claudeshop/contracts": "workspace:*",
    "eventemitter3": "^5.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@claudeshop/config": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
